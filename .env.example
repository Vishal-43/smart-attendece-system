# Smart Attendance System - Environment Configuration

# =============================================================================
# LOCAL DEVELOPMENT
# =============================================================================
# For local development with docker-compose:
#   docker compose -f docker-compose.yml up

# DATABASE_URL=postgresql://smartattendance_user:smartattendance_pass@localhost:5432/smartattendance
# JWT_SECRET=your-local-secret-key
# ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8080

# =============================================================================
# FLY.IO DEPLOYMENT
# =============================================================================
# After deploying backend, get the URL:
#   fly apps list
#   fly info smartattendance-api

# Example:
# DATABASE_URL=postgres://postgres:password@top1.nearest.of.smartattendance-db.internal:5432/smartattendance
# JWT_SECRET=generate-a-secure-32-char-random-string
# ALLOWED_ORIGINS=https://smartattendance-web.fly.dev
# FRONTEND_URL=https://smartattendance-web.fly.dev

# =============================================================================
# SUPABASE (Recommended for Fly.io)
# =============================================================================
# Use Supabase as your PostgreSQL database (free tier available)
# Get connection string from: Supabase Dashboard > Settings > Connection Pooling

# DATABASE_URL=postgres://postgres.xxx:password@aws-0-region.pooler.supabase.com:6543/postgres
# JWT_SECRET=your-secure-random-secret-min-32-chars
# ALLOWED_ORIGINS=https://your-frontend.fly.dev
# FRONTEND_URL=https://your-frontend.fly.dev

# =============================================================================
# WEB FRONTEND API URL
# =============================================================================
# Set this to your deployed backend URL (without /api/v1)
# VITE_API_BASE_URL=https://smartattendance-api.fly.dev
